KBHq9Md29nnaEIPlkf84rnaERnq6zvWvPUqr2ft8M1aS28oN72PdrCzSjY4U6VaAw1EQ==" nonce="" data-cf-beacon="{&quot;rayId&quot;:&quot;9eec4db9ce575910&quot;,&quot;serverTiming&quot;:{&quot;name&quot;:{&quot;cfExtPri&quot;:true,&quot;cfEdge&quot;:true,&quot;cfOrigin&quot;:true,&quot;cfL4&quot;:true,&quot;cfSpeedBrain&quot;:true,&quot;cfCacheStatus&quot;:true}},&quot;version&quot;:&quot;2025.9.1&quot;,&quot;token&quot;:&quot;ef88e2b2e2894e859fa7553dc8d0441c&quot;}" crossorigin="anonymous"></script>
<div class="g6DZMw"><div class="_2UyCZQ"></div><div class="_2UyCZQ"></div></div><div class="_3jkTAA"></div><div class="Bymw5Q"></div><div class="BghEng"><div></div><div></div></div><div id="_r_1_" class="_pFsfA">Canvas</div><div id="_r_3_" class="_pFsfA">The main navigation contains buttons for document level options. To switch between buttons, use the left and right keys and to activate, press Enter. To skip to the canvas, press “Ctrl+F2”.</div><div id="_r_c_" class="_pFsfA">The design title holds the name of your design. To edit the design title, press Enter. To stop editing the design title, press Escape.</div><div id="_r_e_" aria-hidden="true" class="_pFsfA">The canvas is where your design is. To navigate into the page, press Enter. To navigate into groups or elements on the page, press Enter again. Press tab to move to the next page, group, or element. To operate the toolbar, use the “Ctrl+F1” key. If an element is selected, move it using the arrow keys; rotate using the “,” key and “.” key; and resize using the arrow keys with the “Ctrl” key. All of these keys can be modified with the “Shift” key to increase increment.</div><div id="_r_g_" aria-hidden="true" class="_pFsfA">Lock page</div><div id="_r_i_" aria-hidden="true" class="_pFsfA">Duplicate page</div><div id="_r_k_" aria-hidden="true" class="_pFsfA">Add page</div><div id="_r_n_" aria-hidden="true" class="_pFsfA">Notes</div><div id="_r_v_" aria-hidden="true" class="_pFsfA">Zoom</div><div id="_r_11_" aria-hidden="true" class="_pFsfA">Show timer</div><div id="_r_15_" aria-hidden="true" class="_pFsfA">All changes saved</div><div id="_r_17_" aria-hidden="true" class="_pFsfA">Show page thumbnails</div><div id="_r_19_" aria-hidden="true" class="_pFsfA">Grid view</div><div id="_r_1h_" class="_pFsfA">The side panel is where you can apply templates or add elements. To skip to the canvas, press “Ctrl+F2”.</div><div id="_r_47_" aria-hidden="true" class="_pFsfA">Home</div><div id="_r_4b_" aria-hidden="true" class="_pFsfA">Present full screen</div><div id="_r_4i_" aria-hidden="true" class="_pFsfA">Share</div><div id="_r_4h_" class="_pFsfA">This button opens the menu with all the options to share and print your design.</div><div id="_r_4n_" aria-hidden="true" class="_pFsfA">Help Assistant</div><div id="_r_4r_" aria-hidden="true" class="_pFsfA">Analytics</div><div id="_r_4v_" aria-hidden="true" class="_pFsfA">Undo</div><div id="_r_51_" aria-hidden="true" class="_pFsfA">Redo</div><div id="_r_ac_" aria-hidden="true" class="_pFsfA">Color</div><div id="_r_ae_" aria-hidden="true" class="_pFsfA">Stroke style</div><div id="_r_ag_" aria-hidden="true" class="_pFsfA">Corner rounding</div><div id="_r_ai_" aria-hidden="true" class="_pFsfA">Crop</div><div id="_r_ak_" aria-hidden="true" class="_pFsfA">Transparency</div><div id="_r_am_" aria-hidden="true" class="_pFsfA">Animate</div><div id="_r_ao_" aria-hidden="true" class="_pFsfA">Ask Canva</div><div id="_r_aq_" aria-hidden="true" class="_pFsfA">Comment</div><div id="_r_as_" aria-hidden="true" class="_pFsfA">Lock</div><div id="_r_au_" aria-hidden="true" class="_pFsfA">Duplicate</div><div id="_r_b0_" aria-hidden="true" class="_pFsfA">Delete</div><div id="_r_b2_" aria-hidden="true" class="_pFsfA">More</div></body></html>